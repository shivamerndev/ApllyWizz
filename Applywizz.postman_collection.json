							],
							"path": [
								"auth",
								"register"
							]
						},
						"description": "Create a new recruiter account. The response will set a HTTP-only `token` cookie."
					},
					"response": []
				},
				{
					"name": "Login Recruiter",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Extract JWT from cookie and save to environment variable for Bearer token authorization\r",
									"const cookie = pm.cookies.get('token');\r",
									"if (cookie) {\r",
									"    pm.environment.set(\"jwt_token\", cookie);\r",
									"    console.log(\"Cookie token automatically set to environment variable 'jwt_token'\");\r",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"recruiter@applywizz.com\",\n    \"password\": \"securepassword123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/login",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"auth",
								"login"
							]
						},
						"description": "Authenticate recruiter. Sets cookie and outputs log."
					},
					"response": []
				},
