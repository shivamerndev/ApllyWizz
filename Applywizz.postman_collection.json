							"raw": "{{baseUrl}}/jobs?search=engineer&isDuplicate=false&limit=10&page=1&sortBy=postedDate&sortOrder=desc",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"jobs"
							],
							"query": [
								{
									"key": "search",
									"value": "engineer",
									"description": "Full-text or partial keyword filter"
								},
								{
									"key": "company",
									"value": "google",
									"description": "Filter by company name",
									"disabled": true
								},
								{
