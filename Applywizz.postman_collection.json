								{
									"key": "salaryMin",
									"value": "50000",
									"description": "Minimum salary boundary",
									"disabled": true
								},
								{
									"key": "salaryMax",
									"value": "120000",
									"description": "Maximum salary boundary",
									"disabled": true
								},
								{
									"key": "isDuplicate",
									"value": "false",
									"description": "Show/hide duplicates (true / false)"
								},
								{
									"key": "limit",
									"value": "10",
									"description": "Results per page"
								},
								{
									"key": "page",
									"value": "1",
									"description": "Page offset index"
								},
								{
									"key": "sortBy",
									"value": "postedDate",
