		{
			"name": "Duplicates Resolver",
			"item": [
				{
					"name": "Get Duplicate Groups",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{jwt_token}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/duplicates",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"duplicates"
							]
						},
						"description": "Fetch duplicate sets grouped by their canonical parent."
					},
					"response": []
				},
				{
					"name": "Resolve Duplicate Group",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{jwt_token}}",
									"type": "string"
								}
							]
						},
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"action\": \"resolve_unique\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/duplicates/:id",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"duplicates",
								":id"
							],
							"variable": [
								{
									"key": "id",
									"value": "REPLACE_WITH_JOB_ID",
									"description": "The target duplicate job object ID (child, not canonical)"
								}
							]
						},
						"description": "Resolve a near-duplicate job listing.\n\nActions:\n- `resolve_unique`: Re-classifies the child duplicate as a unique canonical listing.\n- `confirm`: Confirms duplicate status without DB modification."
					},
					"response": []
				}
			]
		},
